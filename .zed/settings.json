{
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}", "-c", ".oxfmtrc.json"]
        }
      },
      "format_on_save": "on"
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}", "-c", ".oxfmtrc.json"]
        }
      },
      "format_on_save": "on"
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}", "-c", ".oxfmtrc.json"]
        }
      },
      "format_on_save": "on"
    }
  }
}
