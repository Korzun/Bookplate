{
  "name": "bookplate-server",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "postinstall": "npm run prisma:generate || true",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch . --ext ts,json --exec tsx index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && oxfmt --check \"**/*.ts\" && tsc --noEmit",
    "lint:fix": "oxlint --fix && oxfmt \"**/*.ts\""
  },
  "dependencies": {
    "@korzun/epubcheck-ts": "^0.1.0-beta.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "adm-zip": "^0.6.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.7.1",
    "fflate": "^0.8.3",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^2.1.35",
    "multer": "^2.2.0",
    "nanoid": "^3.3.8",
    "sharp": "^0.34.5",
    "smartcrop": "^2.0.5",
    "smartcrop-sharp": "^2.0.8"
  },
  "optionalDependencies": {
    "@img/sharp-linux-arm64": "^0.34.5",
    "@img/sharp-linux-x64": "^0.34.5",
    "@img/sharp-linuxmusl-arm64": "^0.34.5",
    "@img/sharp-linuxmusl-x64": "^0.34.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.20",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.14",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
