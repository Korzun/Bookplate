# The client dev container (docker-compose `client` service) builds this package
# in isolation with context ./app/client, so the repo-root .npmrc isn't in scope.
# Vite+ overrides `vite` to @voidzero-dev/vite-plus-core (0.2.x), which violates
# the `vite: ^8` peer of @vitejs/plugin-react, so relax peer resolution here too.
legacy-peer-deps=true
