# Vite+ (vite-plus) overrides `vite` to @voidzero-dev/vite-plus-core, whose 0.2.x
# version does not satisfy the `vite: ^8` peer ranges that packages like
# @vitejs/plugin-react declare. The override is intentional and functions at
# runtime (vite-plus-core IS Vite 8), so we relax npm's peer resolution.
legacy-peer-deps=true
